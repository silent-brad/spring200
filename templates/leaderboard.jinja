{% extends "partials/_master.jinja" %}

{% block title %}Leaderboard{% endblock %}

{% block content %}
<article>
  <section>
    <h1>Leaderboard</h1>
    <p>Track everyone's progress towards the Spring92 goal!</p>
  </section>
	
	{% if success_message.is_some() %}
		<div class="success" style="
			background-color: var(--success-oklch-500);
			color: var(--neutral-oklch-50);
			padding: 1rem;
			border-radius: 0.375rem;
			margin-bottom: 1rem;
		">
			{{success_message.get()}}
		</div>
	{% endif %}
	
	<div id="leaderboard-table" class="overflow-auto">
		{% if user_stats.len() > 0 %}
			<table>
				<thead>
					<tr>
						<th>Rank</th>
						<th>Walker</th>
						<th>Miles</th>
						<th>Progress</th>
					</tr>
				</thead>
				<tbody>
					{% importnimja "leaderboard_table.jinja" %}
				</tbody>
			</table>
		{% else %}
			<p style="text-align: center; color: var(--color-text-muted); margin: 2rem 0;">
				No walkers yet. Be the first to <a href="/signup">sign up</a>!
			</p>
		{% endif %}
	</div>
</article>
{%endblock%}
